{
  "name": "@apries/lore",
  "version": "0.5.0",
  "description": "面向 Agent 的本地优先知识编译器。",
  "type": "module",
  "bin": {
    "lore": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Apries406/lore-cli.git"
  },
  "homepage": "https://github.com/Apries406/lore-cli#readme",
  "bugs": {
    "url": "https://github.com/Apries406/lore-cli/issues"
  },
  "keywords": [
    "knowledge-base",
    "llm",
    "okf",
    "cli"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run check"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
